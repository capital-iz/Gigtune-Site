APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8002
APP_TIMEZONE=Africa/Johannesburg

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GIGTUNE_WORDPRESS_BRIDGE_ENABLED=true
GIGTUNE_WORDPRESS_BASE_URL=http://127.0.0.1:8010
GIGTUNE_WORDPRESS_ROOT=
GIGTUNE_WORDPRESS_TIMEOUT=180
GIGTUNE_WORDPRESS_EXECUTION_MODE=cgi
GIGTUNE_WORDPRESS_CGI_BINARY=php-cgi
GIGTUNE_WORDPRESS_DB_CONNECTION=wordpress
GIGTUNE_WORDPRESS_TABLE_PREFIX=wpqx_

WP_DB_HOST=127.0.0.1
WP_DB_PORT=10018
WP_DB_DATABASE=local
WP_DB_USERNAME=root
WP_DB_PASSWORD=root
WP_DB_SOCKET=
WP_DB_CHARSET=utf8mb4
WP_DB_COLLATION=utf8mb4_unicode_ci
WP_MYSQL_ATTR_SSL_CA=

GIGTUNE_POLICY_VERSION_TERMS=v1.1
GIGTUNE_POLICY_VERSION_AUP=v1.1
GIGTUNE_POLICY_VERSION_PRIVACY=v1.1
GIGTUNE_POLICY_VERSION_REFUND=v1.1

GIGTUNE_PAYSTACK_MODE=test
GIGTUNE_PAYSTACK_PUBLIC_KEY=
GIGTUNE_PAYSTACK_SECRET_KEY=

GIGTUNE_YOCO_MODE=test
GIGTUNE_YOCO_TEST_PUBLIC_KEY=
GIGTUNE_YOCO_TEST_SECRET_KEY=
GIGTUNE_YOCO_LIVE_PUBLIC_KEY=
GIGTUNE_YOCO_LIVE_SECRET_KEY=
GIGTUNE_YOCO_WEBHOOK_SECRET=

GIGTUNE_PUSH_ENABLED=true
GIGTUNE_PUSH_VAPID_SUBJECT=mailto:noreply@gigtune.africa
GIGTUNE_PUSH_VAPID_PUBLIC_KEY=
GIGTUNE_PUSH_VAPID_PRIVATE_KEY=
